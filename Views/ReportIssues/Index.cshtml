@model IEnumerable<Prog7312PoePart1.Models.ReportIssue>

@{
    ViewData["Title"] = "Report Issues";
}

<!-- Video Background setup -->
<div class="video-background">
    <video autoplay muted loop id="bgVideo">
        <source src="~/videos/Report issues.mp4" type="video/mp4">
        Your browser does not support HTML5 video.
    </video>
    <div class="video-overlay"></div>
</div>

<!-- Success Toast Notification -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast align-items-center text-bg-success border-0 show" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    @TempData["SuccessMessage"] <!-- Display success message -->
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}

<!-- Main content over video -->
<div class="container content-over-video my-5">
    <h1 class="text-center mb-4 display-5 fw-bold">Reported Issues</h1>

    <!-- Button to create a new issue -->
    <div class="text-center mb-4">
        <a asp-action="Create" class="btn btn-success">Create New Issue</a>
    </div>

    <!-- Table listing all reported issues -->
    <div class="card card-overlay p-3 shadow-sm">
        <div class="table-responsive">
            <table class="table table-dark table-striped table-hover mb-0">
                <thead class="thead-light">
                    <tr>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Category</th>
                        <th>Location</th>
                        <th>Date Reported</th>
                        <th>Media</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count(); i++)
                    {
                        var item = Model.ElementAt(i); 
                                                       <tr>
                                                           <td>@item.Title</td>
                                                           <td>@(item.Description.Length > 50 ? item.Description.Substring(0, 30) + "..." : item.Description)</td>
                                                           <td>@item.Category</td>
                                                           <td>@(item.Location.Length > 20 ? item.Location.Substring(0, 17) + "..." : item.Location)</td>
                                                           <td>@item.DateReported.ToString("yyyy-MM-dd")</td>

                                                <td>
                                                <!-- Show media button if media exists -->
                                                @if (!string.IsNullOrEmpty(item.MediaPath))
                                                {
                                                    <a href="@item.MediaPath" target="_blank" class="btn btn-sm btn-info">View</a>
                                                }
                                                </td>

                            <td class= "text-nowrap d-flex gap-1">
                                <!-- Action buttons -->
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Initialize all Bootstrap toasts
        const toastElList = [].slice.call(document.querySelectorAll('.toast'));
        const toastList = toastElList.map(function (toastEl) {
            return new bootstrap.Toast(toastEl);
        });

        // Show each toast and hide it automatically after 3 seconds
        toastList.forEach(toast => {
            toast.show();
            setTimeout(() => toast.hide(), 3000);
        });
    </script>
}
