@model Prog7312PoePart1.Models.ReportIssue

@{
    ViewData["Title"] = "Delete Report";
}

<!-- Video background -->
<div class="video-background">
    <video autoplay muted loop id="bgVideo">
        <source src="~/videos/Cat.mp4" type="video/mp4" />
        Your browser does not support HTML5 video.
    </video>
    <div class="video-overlay"></div> 
</div>

<!-- Main content container over video -->
<div class="container content-over-video py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card card-overlay shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">Delete Report</h3>
                </div>
                <div class="card-body">

                    <!-- Confirmation message -->
                    <p class="text-center fw-semibold">Are you sure you want to delete this report?</p>

                    <!-- Display report details for reference -->
                    <dl class="row">
                        <dt class="col-sm-3 fw-semibold">Title</dt>
                        <dd class="col-sm-9">@Model.Title</dd>

                        <dt class="col-sm-3 fw-semibold">Description</dt>
                        <dd class="col-sm-9">@Model.Description</dd>

                        <dt class="col-sm-3 fw-semibold">Location</dt>
                        <dd class="col-sm-9">@Model.Location</dd>

                        <dt class="col-sm-3 fw-semibold">Category</dt>
                        <dd class="col-sm-9">@Model.Category</dd>

                        <dt class="col-sm-3 fw-semibold">Date Reported</dt>
                        <dd class="col-sm-9">@Model.DateReported.ToString("yyyy-MM-dd")</dd>

                        <dt class="col-sm-3 fw-semibold">Media</dt>
                        <dd class="col-sm-9">
                            @if (!string.IsNullOrEmpty(Model.MediaPath))
                            {
                                <!-- Link to view attached media -->
                                <a href="@Model.MediaPath" target="_blank" class="btn btn-info btn-sm">View Media</a>
                            }
                            else
                            {
                                <span class="text-muted">No media attached</span>
                            }
                        </dd>
                    </dl>

                    <!-- Delete form -->
                    <form asp-action="Delete">
                        <!-- Hidden field to pass Id -->
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between mt-3">
                            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
